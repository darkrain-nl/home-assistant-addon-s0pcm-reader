FROM python:3.14-alpine
WORKDIR /
COPY rootfs /
COPY --from=ghcr.io/astral-sh/uv:latest /uv /uvx /bin/
RUN uv pip install --system --no-cache --index-strategy unsafe-best-match -r /usr/src/requirements.txt
# Bake in the test configuration
COPY tests/standalone/config/options.json /data/options.json
CMD [ "python3", "/usr/src/s0pcm_reader.py" ]
