# Test container for S0PCM Reader
# This container provides an isolated environment for running tests

# 3.14-alpine
FROM python:3.14-alpine@sha256:5a824eb82cc75361f98611f3cfc5091ea33f10a6ccea4d4ebdabbc523b9a1614

# Install system dependencies
RUN apk add --no-cache \
    gcc \
    musl-dev \
    linux-headers

# Set working directory
WORKDIR /workspace

# Install uv
# 0.11.2
COPY --from=ghcr.io/astral-sh/uv@sha256:1025398289b62de8269e70c45b91ffa37c373f38118d7da036fb8bb8efc85d97 /uv /uvx /bin/

# Install all deps (prod + test group)
COPY pyproject.toml uv.lock ./
RUN --mount=type=cache,target=/root/.cache/uv \
    uv export --frozen --no-emit-project --no-hashes --group test | \
    uv pip install --system --no-cache -r -

# Copy source code and tests
COPY rootfs/usr/src/ ./rootfs/usr/src/
COPY tests/ ./tests/

# Set Python path to find the module
ENV PYTHONPATH=/workspace
ENV PYTHONDONTWRITEBYTECODE=1
ENV PYTHONUNBUFFERED=1

# Default command runs linting then tests
CMD ["sh", "-c", "ruff check . && ruff format --check . && pytest tests/ -v --tb=short"]
