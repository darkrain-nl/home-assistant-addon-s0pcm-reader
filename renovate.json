{
    "$schema": "https://docs.renovatebot.com/renovate-schema.json",
    "description": "Unified updates for S0PCM Reader",
    "extends": [
        "config:recommended",
        ":separateMajorReleases",
        ":combinePatchMinorReleases",
        ":disableDependencyDashboard"
    ],
    "baseBranchPatterns": [
        "dev"
    ],
    "ignorePaths": [
        "**/node_modules/**"
    ],
    "github-actions": {
        "enabled": true
    },
    "dockerfile": {
        "managerFilePatterns": [
            "/(^|/)Dockerfile$/",
            "/(^|/)Dockerfile\\.[^/]+$/"
        ]
    },
    "pip_requirements": {
        "managerFilePatterns": [
            "/(^|/)requirements\\.txt$/",
            "/(^|/)requirements\\.lock$/",
            "/(^|/)requirements-test\\.txt$/",
            "/(^|/)requirements-test\\.lock$/"
        ]
    },
    "customManagers": [
        {
            "customType": "regex",
            "description": "Home Assistant build.yaml base images",
            "managerFilePatterns": [
                "/(^|/)build\\.yaml$/"
            ],
            "matchStrings": [
                "(?<arch>aarch64|amd64):\\s+(?<depName>ghcr\\.io/home-assistant/[^:]+):(?<currentValue>\\S+)"
            ],
            "datasourceTemplate": "docker",
            "versioningTemplate": "docker"
        }
    ],
    "packageRules": [
        {
            "description": "Fix pydantic lookup timeout by using simple API",
            "matchPackageNames": [
                "pydantic"
            ],
            "registryUrls": [
                "https://pypi.org/simple/"
            ]
        },
        {
            "description": "Do NOT enable automerge for python dependencies. Lock files (.lock) must be manually regenerated via .agent/workflows/dependencies.md when .txt files update.",
            "matchUpdateTypes": [
                "minor",
                "patch",
                "pin",
                "digest"
            ],
            "automerge": false
        },
        {
            "matchPackageNames": [
                "ghcr.io/home-assistant/**"
            ],
            "groupName": "Home Assistant Base Images"
        }
    ]
}