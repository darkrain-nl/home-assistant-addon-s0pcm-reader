{
    "$schema": "https://docs.renovatebot.com/renovate-schema.json",
    "description": "Unified updates for S0PCM Reader",
    "extends": [
        "config:recommended",
        ":separateMajorReleases",
        ":combinePatchMinorReleases",
        ":disableDependencyDashboard",
        ":rebaseStalePrs"
    ],
    "minimumReleaseAge": "3 days",
    "baseBranchPatterns": [
        "dev"
    ],
    "ignorePaths": [
        "**/node_modules/**"
    ],
    "github-actions": {
        "enabled": true
    },
    "dockerfile": {
        "managerFilePatterns": [
            "/(^|/)Dockerfile$/",
            "/(^|/)Dockerfile\\.[^/]+$/"
        ]
    },
    "lockFileMaintenance": {
        "enabled": true
    },
    "customManagers": [
        {
            "customType": "regex",
            "description": "Home Assistant build.yaml base images",
            "managerFilePatterns": [
                "/(^|/)build\\.yaml$/"
            ],
            "matchStrings": [
                "(?<arch>aarch64|amd64):\\s+(?<depName>ghcr\\.io/home-assistant/[^:]+):(?<currentValue>\\S+)"
            ],
            "datasourceTemplate": "docker",
            "versioningTemplate": "docker"
        }
    ],
    "packageRules": [
        {
            "matchManagers": ["github-actions"],
            "minimumReleaseAge": "5 days"
        },
        {
            "matchPackageNames": [
                "ghcr.io/home-assistant/**"
            ],
            "groupName": "Home Assistant Base Images"
        }
    ]
}